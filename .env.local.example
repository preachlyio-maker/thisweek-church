# Supabase — get from supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Vercel — generate a random string, e.g. openssl rand -hex 32
REVALIDATE_SECRET=your-random-secret-here

# Admin /admin/seed form — generate a random string, e.g. openssl rand -hex 32
ADMIN_SEED_SECRET=your-admin-secret-here

# Pipeline (pipeline/run.js) — optional overrides
# ARTICLE_MODEL=claude-sonnet-4-6
# ARTICLE_AUTOPUBLISH=false   # true = publish AI articles immediately; false = save as draft for review

# YouTube Data API key (optional) — enables the auto-refreshing "Watch This Week"
# video wall. Get a free key at console.cloud.google.com (enable "YouTube Data API v3").
# Without it, the seeded videos simply stay put.
# YOUTUBE_API_KEY=your-youtube-api-key-here
